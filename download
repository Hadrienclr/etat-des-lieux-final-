export class SignatureCanvas {
  constructor(canvas, onChange = () => {}) {
    if (!(canvas instanceof HTMLCanvasElement)) {
      throw new TypeError("Un canvas valide est requis.");
    }

    this.canvas = canvas;
    this.context = canvas.getContext("2d");
    this.onChange = onChange;
    this.drawing = false;
    this.empty = true;
    this.lastPoint = null;
    this.pendingDataUrl = "";

    this.handlePointerDown = this.handlePointerDown.bind(this);
    this.handlePointerMove = this.handlePointerMove.bind(this);
    this.handlePointerUp = this.handlePointerUp.bind(this);
    this.resize = this.resize.bind(this);

    this.canvas.style.touchAction = "none";
    this.canvas.addEventListener("pointerdown", this.handlePointerDown);
    this.canvas.addEventListener("pointermove", this.handlePointerMove);
    this.canvas.addEventListener("pointerup", this.handlePointerUp);
    this.canvas.addEventListener("pointercancel", this.handlePointerUp);
    this.canvas.addEventListener("pointerleave", this.handlePointerUp);

    this.resizeObserver = new ResizeObserver(this.resize);
    this.resizeObserver.observe(this.canvas.parentElement);
    this.resize();
  }

  resize() {
    const previousData = this.empty ? "" : this.toDataURL();
    const rectangle = this.canvas.getBoundingClientRect();
    const pixelRatio = Math.max(window.devicePixelRatio || 1, 1);
    const width = Math.max(Math.round(rectangle.width * pixelRatio), 1);
    const height = Math.max(Math.round(rectangle.height * pixelRatio), 1);

    if (this.canvas.width === width && this.canvas.height === height) {
      return;
    }

    this.canvas.width = width;
    this.canvas.height = height;
    this.context.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0);
    this.context.lineWidth = 2.2;
    this.context.lineCap = "round";
    this.context.lineJoin = "round";
    this.context.strokeStyle = "#0f172a";

    if (previousData) {
      this.fromDataURL(previousData);
    } else if (this.pendingDataUrl) {
      const pending = this.pendingDataUrl;
      this.pendingDataUrl = "";
      this.fromDataURL(pending);
    }
  }

  pointFromEvent(event) {
    const rectangle = this.canvas.getBoundingClientRect();
    return {
      x: event.clientX - rectangle.left,
      y: event.clientY - rectangle.top
    };
  }

  handlePointerDown(event) {
    event.preventDefault();
    this.canvas.setPointerCapture?.(event.pointerId);
    this.drawing = true;
    this.lastPoint = this.pointFromEvent(event);
    this.context.beginPath();
    this.context.moveTo(this.lastPoint.x, this.lastPoint.y);
  }

  handlePointerMove(event) {
    if (!this.drawing) return;
    event.preventDefault();

    const nextPoint = this.pointFromEvent(event);
    const middlePoint = {
      x: (this.lastPoint.x + nextPoint.x) / 2,
      y: (this.lastPoint.y + nextPoint.y) / 2
    };

    this.context.quadraticCurveTo(
      this.lastPoint.x,
      this.lastPoint.y,
      middlePoint.x,
      middlePoint.y
    );
    this.context.stroke();

    this.lastPoint = nextPoint;
    this.empty = false;
  }

  handlePointerUp(event) {
    if (!this.drawing) return;
    event.preventDefault();
    this.drawing = false;
    this.lastPoint = null;
    this.canvas.releasePointerCapture?.(event.pointerId);
    this.onChange(this.toDataURL());
  }

  clear({ notify = true } = {}) {
    this.context.clearRect(0, 0, this.canvas.width, this.canvas.height);
    this.empty = true;
    this.pendingDataUrl = "";
    if (notify) this.onChange("");
  }

  isEmpty() {
    return this.empty;
  }

  toDataURL() {
    return this.empty ? "" : this.canvas.toDataURL("image/png");
  }

  fromDataURL(dataUrl) {
    if (!dataUrl) {
      this.clear({ notify: false });
      return;
    }

    const rectangle = this.canvas.getBoundingClientRect();
    if (rectangle.width < 10 || rectangle.height < 10) {
      this.pendingDataUrl = dataUrl;
      return;
    }

    const image = new Image();
    image.onload = () => {
      this.context.clearRect(0, 0, this.canvas.width, this.canvas.height);
      this.context.drawImage(image, 0, 0, rectangle.width, rectangle.height);
      this.empty = false;
    };
    image.src = dataUrl;
  }
}
